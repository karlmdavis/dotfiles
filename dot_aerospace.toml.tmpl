config-version = 2

after-startup-command = []
start-at-login = true

enable-normalization-flatten-containers = true
enable-normalization-opposite-orientation-for-nested-containers = true

accordion-padding = 30
default-root-container-layout = 'tiles'
default-root-container-orientation = 'auto'

on-focused-monitor-changed = ['move-mouse monitor-lazy-center']
automatically-unhide-macos-hidden-apps = false

persistent-workspaces = ["1", "2", "3", "4", "5", "6", "7", "8", "9", "A", "B",
                         "C", "D", "E", "F", "G", "I", "M", "N", "O", "P", "Q",
                         "R", "S", "T", "U", "V", "W", "X", "Y", "Z"]

on-mode-changed = []

[key-mapping]
    preset = 'qwerty'

[gaps]
    inner.horizontal = 0
    inner.vertical =   0
    outer.left =       0
    outer.bottom =     0
    outer.top =        0
    outer.right =      0

[mode.main.binding]

    alt-slash = 'layout tiles horizontal vertical'
    alt-comma = 'layout accordion horizontal vertical'

    alt-h = 'focus left'
    alt-j = 'focus down'
    alt-k = 'focus up'
    alt-l = 'focus right'

    alt-shift-h = 'move left'
    alt-shift-j = 'move down'
    alt-shift-k = 'move up'
    alt-shift-l = 'move right'

    ctrl-alt-shift-h = 'join-with left'
    ctrl-alt-shift-j = 'join-with down'
    ctrl-alt-shift-k = 'join-with up'
    ctrl-alt-shift-l = 'join-with right'

    alt-minus = 'resize smart -50'
    alt-equal = 'resize smart +50'

    alt-1 = ['workspace 1', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 1']
    alt-2 = ['workspace 2', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 2']
    alt-3 = ['workspace 3', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 3']
    alt-4 = ['workspace 4', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 4']
    alt-5 = ['workspace 5', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 5']
    alt-6 = ['workspace 6', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 6']
    alt-7 = ['workspace 7', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 7']
    alt-8 = ['workspace 8', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 8']
    alt-9 = ['workspace 9', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 9']
    alt-a = ['workspace A', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh A']
    alt-b = ['workspace B', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh B']
    alt-c = ['workspace C', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh C']
    alt-d = ['workspace D', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh D']
    alt-e = ['workspace E', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh E']
    alt-f = ['workspace F', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh F']
    alt-g = ['workspace G', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh G']
    alt-i = ['workspace I', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh I']
    alt-m = ['workspace M', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh M']
    alt-n = ['workspace N', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh N']
    alt-o = ['workspace O', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh O']
    alt-p = ['workspace P', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh P']
    alt-q = ['workspace Q', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh Q']
    alt-r = ['workspace R', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh R']
    alt-s = ['workspace S', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh S']
    alt-t = ['workspace T', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh T']
    alt-u = ['workspace U', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh U']
    alt-v = ['workspace V', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh V']
    alt-w = ['workspace W', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh W']
    alt-x = ['workspace X', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh X']
    alt-y = ['workspace Y', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh Y']
    alt-z = ['workspace Z', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh Z']

    alt-shift-1 = ['move-node-to-workspace 1', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 1 "→ "']
    alt-shift-2 = ['move-node-to-workspace 2', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 2 "→ "']
    alt-shift-3 = ['move-node-to-workspace 3', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 3 "→ "']
    alt-shift-4 = ['move-node-to-workspace 4', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 4 "→ "']
    alt-shift-5 = ['move-node-to-workspace 5', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 5 "→ "']
    alt-shift-6 = ['move-node-to-workspace 6', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 6 "→ "']
    alt-shift-7 = ['move-node-to-workspace 7', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 7 "→ "']
    alt-shift-8 = ['move-node-to-workspace 8', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 8 "→ "']
    alt-shift-9 = ['move-node-to-workspace 9', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh 9 "→ "']
    alt-shift-a = ['move-node-to-workspace A', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh A "→ "']
    alt-shift-b = ['move-node-to-workspace B', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh B "→ "']
    alt-shift-c = ['move-node-to-workspace C', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh C "→ "']
    alt-shift-d = ['move-node-to-workspace D', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh D "→ "']
    alt-shift-e = ['move-node-to-workspace E', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh E "→ "']
    alt-shift-f = ['move-node-to-workspace F', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh F "→ "']
    alt-shift-g = ['move-node-to-workspace G', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh G "→ "']
    alt-shift-i = ['move-node-to-workspace I', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh I "→ "']
    alt-shift-m = ['move-node-to-workspace M', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh M "→ "']
    alt-shift-n = ['move-node-to-workspace N', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh N "→ "']
    alt-shift-o = ['move-node-to-workspace O', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh O "→ "']
    alt-shift-p = ['move-node-to-workspace P', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh P "→ "']
    alt-shift-q = ['move-node-to-workspace Q', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh Q "→ "']
    alt-shift-r = ['move-node-to-workspace R', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh R "→ "']
    alt-shift-s = ['move-node-to-workspace S', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh S "→ "']
    alt-shift-t = ['move-node-to-workspace T', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh T "→ "']
    alt-shift-u = ['move-node-to-workspace U', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh U "→ "']
    alt-shift-v = ['move-node-to-workspace V', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh V "→ "']
    alt-shift-w = ['move-node-to-workspace W', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh W "→ "']
    alt-shift-x = ['move-node-to-workspace X', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh X "→ "']
    alt-shift-y = ['move-node-to-workspace Y', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh Y "→ "']
    alt-shift-z = ['move-node-to-workspace Z', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh Z "→ "']

    alt-tab = ['workspace-back-and-forth', 'exec-and-forget ~/.config/aerospace/hud-display-workspace-name.sh']
    alt-shift-tab = 'move-workspace-to-monitor --wrap-around next'

    alt-shift-semicolon = 'mode service'

[mode.service.binding]
    esc = ['reload-config', 'mode main']
    r = ['flatten-workspace-tree', 'mode main']
    f = ['layout floating tiling', 'mode main']
    backspace = ['close-all-windows-but-current', 'mode main']
{{- $yaml := joinPath .chezmoi.homeDir ".config/aerospace/workspaces.yaml" }}
{{- if stat $yaml }}
{{- $content := output "cat" $yaml }}
{{- $data := fromYaml $content }}
{{- if and $data (index $data "window-rules") }}

# Window detection rules (generated from ~/.config/aerospace/workspaces.yaml)
{{ range index $data "window-rules" }}
[[on-window-detected]]
if.app-id = '{{ index . "app-id" }}'
{{- if index . "title-regex" }}
if.window-title-regex-substring = '{{ index . "title-regex" }}'
{{- end }}
run = 'move-node-to-workspace {{ .workspace }}'
{{ end }}
{{- end }}
{{- end }}
