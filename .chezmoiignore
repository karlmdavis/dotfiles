README.md
LICENSE
CLAUDE.md
CONTRIBUTING.md
dev/

# Ignore testing and development files.
mise.toml
.githooks/
docs/
test/

# Embedded mini-project dev files: keep the tooling/tests/caches out of the installed target.
# (Only the runtime package dir under each .local/lib/<project>/ installs.)
.local/lib/aerospace-workspaces/mise.toml
.local/lib/aerospace-workspaces/pyproject.toml
.local/lib/aerospace-workspaces/tests
.local/lib/cmd-notify/mise.toml
.local/lib/cmd-notify/pyproject.toml
.local/lib/cmd-notify/tests
.local/lib/**/__pycache__
.local/lib/**/.pytest_cache
.local/lib/**/*.pyc

{{ if ne .chezmoi.os "darwin" }}
# Only apply MacOS-only files when we're _actually_ on MacOS.
Library/
.aerospace.toml
.config/aerospace/
.config/swiftbar/
.hammerspoon/
# Shared package behind the (macOS-only) SwiftBar plugin + AeroSpace HUD.
.local/lib/aerospace-workspaces/
{{ end }}
{{- if ne .chezmoi.os "linux" }}
# Only apply Linux-only files when we're _actually on_ Linux.
.config/nushell/config.nu
.config/nushell/local.nu
.config/sway/
.config/i3
.config/i3status
{{- end }}

{{ if eq .chezmoi.os "darwin" }}
# iTerm2 remote-host profiles deploy per-machine (the base `zellij` profile always applies):
#   - never deploy the profile for the host you're on (no SSHing into yourself); keyed on
#     hostname, so karl-<hostname>.json self-excludes (e.g. karl-mantis.json on mantis).
#   - on CMS (work) workstations, deploy none of the remote-host profiles, so the work machine
#     can't reach personal systems.
Library/Application Support/iTerm2/DynamicProfiles/karl-{{ .chezmoi.hostname }}.json
{{- if .isCMS }}
Library/Application Support/iTerm2/DynamicProfiles/karl-scaleway-mini.json
Library/Application Support/iTerm2/DynamicProfiles/karl-eddings.json
Library/Application Support/iTerm2/DynamicProfiles/karl-mantis.json
Library/Application Support/iTerm2/DynamicProfiles/work-wifi-longview.json
{{- end }}
{{- end }}
