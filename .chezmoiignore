.config/sway/
.config/i3
.config/i3status
{{- end }}

# Zellij web server TLS certificates are generated into the target dir by
# run_generate-zellij-web-certs.sh.tmpl and never enter the source repo.
# Listed here to prevent accidental `chezmoi add` of these files.
.config/zellij/server.crt
.config/zellij/server.key
