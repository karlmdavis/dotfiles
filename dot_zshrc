##
# History — mirrors nushell: virtually unlimited, write on each command, per-session isolation.
#
# Note: Zsh has no truly-unlimited flag (no -1 equivalent); the large integer is a practical
# ceiling. EXTENDED_HISTORY stores each entry as `: timestamp:elapsed;command`, providing
# timestamps and command duration natively — the closest zsh gets to structured storage.
# INC_APPEND_HISTORY_TIME writes after the command completes (so elapsed time is known),
# mirroring nushell's sync_on_enter = true. Per-session isolation is zsh's default.
##

HISTFILE=~/.zsh_history
HISTSIZE=5000000000
SAVEHIST=5000000000
setopt EXTENDED_HISTORY         # store `: timestamp:elapsed;command` format
setopt INC_APPEND_HISTORY_TIME  # write after completion to capture elapsed; mirrors sync_on_enter
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

##
# PATH
#
# Intentionally NOT set here. PATH entries live in ~/.zprofile (login, after macOS path_helper) via the
# shared shell-env snippet — kept consistent with bash and nushell. ~/.zshenv only enforces uniqueness
# (typeset -U path). See .chezmoitemplates/shell-env.sh.
##

##
# Completion.
#
# Initializes zsh's completion system so that tab completion works for commands, flags, and
# arguments. Without this, only basic filename completion is available.
# Only rebuilds the completion dump when it is older than 24 hours to avoid startup latency;
# compinit -C skips the security check on subsequent loads (safe on a personal machine).
##

autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

##
# Aliases.
##

# `td` — Todoist CLI via pinned npx fetch (no global install).
alias td='npx --package=@doist/todoist-cli@1.60.0 -- td'

##
# Tool version manager.
##

# mise — installs a precmd hook that rewrites PATH on each `cd` based on the nearest
# mise.toml / .tool-versions. Idempotent; the guard makes this a no-op when mise isn't installed
# (mise itself is in the package manifest, so on a freshly-applied system it will be present).
command -v mise &>/dev/null && eval "$(mise activate zsh)"


##
# Prompt.
##

# Initialize Starship prompt if installed (matches bash and nushell setup).
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi


##
# Long-running command notifications.
#
# Uses zsh's native preexec/precmd hooks (much cleaner than bash's DEBUG trap dance).
# Helper is a no-op when missing or when CMD_NOTIFY_DISABLE=1.
##

if [[ -x $HOME/.local/bin/cmd-notify ]]; then
  __cmd_notify_preexec() {
    __cmd_notify_start=$EPOCHSECONDS
    __cmd_notify_cmd=$1
  }
  __cmd_notify_precmd() {
    local exit=$?
    [[ -z ${__cmd_notify_start:-} ]] && return
    "$HOME/.local/bin/cmd-notify" "$__cmd_notify_cmd" $((EPOCHSECONDS - __cmd_notify_start)) "$exit" "$PWD" 2>/dev/null
    unset __cmd_notify_start __cmd_notify_cmd
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook preexec __cmd_notify_preexec
  add-zsh-hook precmd __cmd_notify_precmd
fi
