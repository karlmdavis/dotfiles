#!/bin/sh
# chezmoi modify_ script for ~/.ssh/authorized_keys.
#
# chezmoi pipes the live target file in on stdin and replaces the target with
# our stdout. We guarantee the two canonical public keys below are present,
# normalize their comment field to the canonical value, and leave every other
# line (other keys, options-prefixed entries, comments, blank lines) untouched.
# Match is by key blob (field 2), which uniquely identifies the key.
set -eu

exec awk '
BEGIN {
  n = 0

  type[++n] = "ssh-rsa"
  blob[n]    = ""
  comment[n] = "The personal, passphrase-protected SSH key for Karl M. Davis."

  type[++n] = "ecdsa-sha2-nistp256"
  blob[n]    = "AAAAE2VjZHNhLXNoYTItbmlzdHAyNTYAAAAIbmlzdHAyNTYAAABBBEzoHynGA3rnwhji/xbIPzyzeelhXwxvJynckxuwyylMqOBD2mIVZR63Zn6J5gZbQMNcgGXPrvr4HgCVO0QBp5E="
  comment[n] = "karl-iphone-faceid-key"

  for (i = 1; i <= n; i++) {
    by_blob[blob[i]] = i
    needed[i] = 1
  }
}

# Pass blank lines and comments through unchanged.
NF == 0 || $1 ~ /^#/ { print; next }

{
  # Field 2 is the key blob on a normal authorized_keys entry. For
  # options-prefixed lines (e.g. command="...",no-pty ssh-rsa AAAA... comment),
  # $2 will be something else and will not match a known blob, so those lines
  # fall through and print verbatim.
  if ($2 in by_blob) {
    i = by_blob[$2]
    print type[i] " " blob[i] " " comment[i]
    needed[i] = 0
    next
  }
  print
}

END {
  for (i = 1; i <= n; i++) {
    if (needed[i]) {
      print type[i] " " blob[i] " " comment[i]
    }
  }
}
'
