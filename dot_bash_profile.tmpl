#!/usr/bin/env bash

##
# ~/.bash_profile (managed by chezmoi) — bash LOGIN shells, sourced after /etc/profile (path_helper).
#
# Shared PATH/utility setup (consistent with zsh ~/.zprofile and nushell config.nu), then interactive
# bash setup (~/.bashrc), then the interactive zellij launcher. Background/non-interactive shells are
# unaffected. Opt out of the zellij launch with NO_ZELLIJ=1.
#
# Canonically:
# - ~/.bash_profile holds (potentially non-idempotent) environment setup, e.g. PATH and exports.
# - ~/.bashrc holds idempotent interactive setup, e.g. prompt, completions, aliases, functions.
##


{{ template "shell-env.sh" . }}

##
# Interactive bash setup (prompt, history, completion, aliases)
##

# Source ~/.bashrc (also sourced directly for non-login interactive shells).
[ -f "$HOME/.bashrc" ] && . "$HOME/.bashrc"

{{ template "zellij-launch.sh" . }}
